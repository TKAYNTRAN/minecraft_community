PORT=5000

# Database Configuration (Local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minecraft_seeds
DB_USER=postgres
DB_PASSWORD=tkaido

# OR use Supabase DATABASE_URL (comment out local DB config above if using Supabase)
# Direct connection (works locally; on Render prefer pooler URL below if IPv6 errors occur)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# Supabase Connection Pooler (recommended for Render/Vercel — Supabase Dashboard > Settings > Database)
# Session mode (port 5432) or Transaction mode (port 6543):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

JWT_SECRET=your_jwt_secret_key

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=post-images
